# ── LLM Configuration (DeepSeek - OpenAI compatible) ─────
LLM_API_KEY=sk-your-deepseek-api-key-here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
EMBEDDING_MODEL=deepseek-chat

# ── Neo4j ─────────────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=graphiti_dev

# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_URL=postgresql://postgres:postgres@postgres:5432/kgplatform

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── MinIO ─────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=documents

# ── Service URLs (internal docker network) ────────────────
GRAPHITI_SERVICE_URL=http://graphiti-server:8100
BACKEND_URL=http://backend:8080

# ── Optional: for local development outside Docker ────────
# NEO4J_URI=bolt://localhost:7687
# POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/kgplatform
# REDIS_URL=redis://localhost:6379/0
# MINIO_ENDPOINT=localhost:9000
# GRAPHITI_SERVICE_URL=http://localhost:8100
# BACKEND_URL=http://localhost:8080
