# ── LLM Configuration ─────────────────────────────────────
LLM_API_KEY=sk-your-llm-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# Embedding via local Ollama (host.docker.internal from inside Docker)
EMBEDDING_BASE_URL=http://host.docker.internal:11434/v1
EMBEDDING_MODEL=qwen3-embedding:0.6b

# ── Neo4j ─────────────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=graphiti_dev

# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_URL=postgresql://postgres:postgres@postgres:5432/kgplatform

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── MinIO ─────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=documents

# ── Service URLs (internal docker network) ────────────────
GRAPHITI_SERVICE_URL=http://graphiti-server:8100
BACKEND_URL=http://backend:8080
